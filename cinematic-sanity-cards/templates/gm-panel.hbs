<section class="csc-section">
  <h2>Reveal Card</h2>
  <label>Target Player <select name="targetUserId">{{#each users}}<option value="{{id}}">{{name}}{{#if active}} ●{{/if}}{{#if isGM}} (GM){{/if}}</option>{{/each}}</select></label>
  <label>Folder/Deck <select name="revealFolderId">{{#each folders}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label>
  <label>Card <select name="revealCardId"></select></label>
  <div class="csc-preview"><span>No card selected</span></div>
  <div class="csc-row"><button type="button" data-action="showSelected">Show Selected Card</button><button type="button" data-action="showRandom">Show Random From Folder</button></div>
</section>
<section class="csc-section">
  <h2>Manage Folders</h2>
  <ol class="csc-list">{{#each folders}}<li><strong>{{name}}</strong> <code>{{id}}</code><button type="button" data-action="deleteFolder" data-folder-id="{{id}}">Delete</button></li>{{/each}}</ol>
  <div class="csc-grid"><label>Name <input name="folderName" type="text"></label><label>ID <input name="folderId" type="text"></label><button type="button" data-action="saveFolder">Add Folder</button></div>
</section>
<section class="csc-section">
  <h2>Manage Cards</h2>
  <input type="hidden" name="cardOriginalId">
  <div class="csc-grid"><label>Card Name <input name="cardName" type="text"></label><label>Card ID <input name="cardId" type="text"></label><label>Folder <select name="cardFolderId">{{#each folders}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label><label>Image Path <input name="cardImage" type="text"></label><button type="button" data-action="browseImage">Browse/Upload</button><button type="button" data-action="saveCard">Save Card</button></div>
  <ol class="csc-card-list">{{#each cards}}<li><img src="{{image}}" alt="{{name}}"><span><strong>{{name}}</strong><code>{{id}}</code><small>{{folderId}}</small></span><button type="button" data-action="editCard" data-card-id="{{id}}">Edit</button><button type="button" data-action="deleteCard" data-card-id="{{id}}">Delete</button></li>{{/each}}</ol>
</section>
